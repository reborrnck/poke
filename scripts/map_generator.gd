func _ready() -> void:
	if auto_generate and tile_set:
		generate()


func generate() -> void:
	clear()
	for y in range(MAP_DATA.size()):
		var row := MAP_DATA[y]
		for x in range(row.size()):
			var tile_id := row[x]
			if tile_id == T.NONE:
				continue
			set_cell(Vector2i(x, y), 0, Vector2i(tile_id, 0))
